<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Адмін — Зоряна Памʼять</title>
<style>
:root{
  --bg:#03070e;--surface:#070d1a;--surface2:#0a1220;
  --border:rgba(255,255,255,.08);--border2:rgba(255,255,255,.14);
  --text:#d0dce8;--text2:#8a9cb0;--muted:#3a5068;
  --accent:#00c8ff;--yellow:#d4a800;--red:#e05050;--green:#3a9a60;
  --radius:8px;
}
*{box-sizing:border-box;margin:0;padding:0}
html,body{height:100%;font-family:'Segoe UI',sans-serif;background:var(--bg);color:var(--text);font-size:13px}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-thumb{background:var(--border2);border-radius:4px}

/* Layout */
#layout{display:flex;height:100vh}
#sidebar{width:220px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;flex-shrink:0}
#main{flex:1;overflow-y:auto;padding:24px}

/* Sidebar */
#sidebar-logo{padding:18px 16px;border-bottom:1px solid var(--border)}
#sidebar-logo h1{font-size:13px;font-weight:700;color:var(--yellow)}
#sidebar-logo p{font-size:11px;color:var(--muted);margin-top:2px}
.nav-item{display:flex;align-items:center;gap:10px;padding:11px 16px;cursor:pointer;color:var(--text2);transition:background .15s,color .15s}
.nav-item:hover{background:rgba(255,255,255,.04);color:var(--text)}
.nav-item.active{background:rgba(0,200,255,.08);color:var(--accent);border-right:2px solid var(--accent)}
.nav-ico{font-size:16px;width:20px;text-align:center}
#admin-info{margin-top:auto;padding:14px 16px;border-top:1px solid var(--border);font-size:11px;color:var(--muted)}
#btn-logout-admin{width:100%;margin-top:8px;background:rgba(224,80,80,.1);border:1px solid rgba(224,80,80,.2);border-radius:var(--radius);color:#e05050;padding:7px;cursor:pointer;font-size:11px}
#btn-logout-admin:hover{background:rgba(224,80,80,.2)}

/* Login */
#login-screen{position:fixed;inset:0;background:var(--bg);display:flex;align-items:center;justify-content:center;z-index:999}
.login-box{background:var(--surface);border:1px solid var(--border2);border-radius:14px;padding:32px;width:340px}
.login-box h2{font-size:16px;color:var(--yellow);margin-bottom:6px}
.login-box p{font-size:11px;color:var(--muted);margin-bottom:20px}
.lf{display:flex;flex-direction:column;gap:5px;margin-bottom:12px}
.lf label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.lf input{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:var(--radius);color:var(--text);padding:8px 10px;font-size:12px;outline:none}
.lf input:focus{border-color:rgba(0,200,255,.4)}
#btn-login-admin{width:100%;background:linear-gradient(135deg,#0e2860,#0088bb);border:none;border-radius:var(--radius);color:#a8e0f8;padding:12px;font-weight:700;font-size:12px;cursor:pointer;margin-top:4px}
#login-err{color:#e05050;font-size:11px;margin-top:8px;display:none}

/* Sections */
.section{display:none}
.section.active{display:block}
.section-title{font-size:18px;font-weight:700;color:var(--text);margin-bottom:20px;display:flex;align-items:center;gap:10px}

/* Stats cards */
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:28px}
.stat-card{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:16px}
.stat-card .num{font-size:28px;font-weight:700;color:var(--accent);font-variant-numeric:tabular-nums}
.stat-card .lbl{font-size:11px;color:var(--muted);margin-top:3px}

/* Table */
.tbl-wrap{background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);overflow:hidden;margin-bottom:20px}
table{width:100%;border-collapse:collapse}
th{background:var(--surface2);padding:10px 12px;text-align:left;font-size:10px;text-transform:uppercase;letter-spacing:.07em;color:var(--muted);border-bottom:1px solid var(--border)}
td{padding:9px 12px;border-bottom:1px solid var(--border);vertical-align:middle;font-size:12px}
tr:last-child td{border-bottom:none}
tr:hover td{background:rgba(255,255,255,.02)}
.badge{display:inline-block;padding:2px 8px;border-radius:12px;font-size:10px}
.badge-green{background:rgba(58,154,96,.15);color:#3a9a60;border:1px solid rgba(58,154,96,.3)}
.badge-red{background:rgba(224,80,80,.15);color:#e05050;border:1px solid rgba(224,80,80,.3)}
.badge-yellow{background:rgba(212,168,0,.15);color:#d4a800;border:1px solid rgba(212,168,0,.3)}
.badge-blue{background:rgba(0,200,255,.1);color:#00c8ff;border:1px solid rgba(0,200,255,.2)}

/* Buttons */
.btn{display:inline-flex;align-items:center;gap:5px;padding:5px 10px;border-radius:6px;border:1px solid var(--border);background:rgba(255,255,255,.05);color:var(--text2);cursor:pointer;font-size:11px;transition:background .15s,color .15s}
.btn:hover{background:rgba(255,255,255,.1);color:var(--text)}
.btn-red{border-color:rgba(224,80,80,.3);color:#e05050;background:rgba(224,80,80,.08)}
.btn-red:hover{background:rgba(224,80,80,.18)}
.btn-green{border-color:rgba(58,154,96,.3);color:#3a9a60;background:rgba(58,154,96,.08)}
.btn-green:hover{background:rgba(58,154,96,.18)}
.btn-blue{border-color:rgba(0,200,255,.3);color:#00c8ff;background:rgba(0,200,255,.08)}
.btn-blue:hover{background:rgba(0,200,255,.18)}
.btn-primary{background:linear-gradient(135deg,#0e2860,#0088bb);border-color:#0088bb;color:#a8e0f8;padding:8px 16px;font-size:12px}
.btn-primary:hover{opacity:.88}

/* Color editor */
.colors-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:10px;margin-bottom:20px}
.color-row{display:flex;align-items:center;gap:10px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius);padding:10px 12px}
.color-preview{width:32px;height:32px;border-radius:6px;border:1px solid var(--border2);flex-shrink:0;cursor:pointer}
.color-info{flex:1;min-width:0}
.color-key{font-size:10px;color:var(--muted);margin-bottom:2px;font-family:monospace}
.color-lbl{font-size:12px;color:var(--text)}
.color-val{font-size:11px;color:var(--text2);font-family:monospace;margin-top:2px}
.color-input{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:5px 8px;font-size:11px;font-family:monospace;width:160px;outline:none}
.color-input:focus{border-color:rgba(0,200,255,.4)}

/* Edit modal */
#edit-modal{position:fixed;inset:0;background:rgba(0,0,0,.75);z-index:500;display:none;align-items:center;justify-content:center}
#edit-modal.open{display:flex}
.edit-box{background:#060c1a;border:1px solid var(--border2);border-radius:14px;width:560px;max-width:95vw;max-height:90vh;overflow-y:auto;padding:24px;position:relative}
.edit-box h3{font-size:14px;color:var(--yellow);margin-bottom:18px}
.ef-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.ef-full{grid-column:1/-1}
.ef{display:flex;flex-direction:column;gap:4px}
.ef label{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}
.ef input,.ef select,.ef textarea{background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:7px;color:var(--text);padding:7px 10px;font-size:12px;font-family:inherit;outline:none}
.ef input:focus,.ef select:focus,.ef textarea:focus{border-color:rgba(0,200,255,.4)}
.ef textarea{min-height:70px;resize:vertical}
.edit-actions{display:flex;gap:10px;justify-content:flex-end;margin-top:16px}
#modal-close-btn{position:absolute;top:14px;right:14px;background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer}

/* Preview bar */
#preview-bar{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius);padding:14px 18px;margin-bottom:16px;display:flex;align-items:center;gap:14px;flex-wrap:wrap}
#preview-bar .pbr-label{font-size:11px;color:var(--muted)}
#preview-logo{font-size:14px;font-weight:700}
#preview-map{width:120px;height:60px;border-radius:6px;border:1px solid var(--border)}

/* Online dot */
.online-dot{width:7px;height:7px;border-radius:50%;background:#3a9a60;display:inline-block;margin-right:4px}

/* Notification */
#admin-notif{position:fixed;bottom:20px;right:20px;background:#0c1c0c;border:1px solid #2a6a3a;border-radius:var(--radius);padding:10px 18px;font-size:12px;color:#70b870;z-index:999;opacity:0;transition:opacity .3s;pointer-events:none}
#admin-notif.show{opacity:1}
#admin-notif.err{background:#1c0c0c;border-color:#6a2a2a;color:#b87070}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="login-screen">
  <div class="login-box">
    <h2>🔐 Адміністратор</h2>
    <p>Вхід до панелі управління</p>
    <div class="lf"><label>Email</label><input type="email" id="adm-email" value="admin@admin.com"></div>
    <div class="lf"><label>Пароль</label><input type="password" id="adm-pass" value="Admin"></div>
    <button id="btn-login-admin" onclick="adminLogin()">Увійти</button>
    <div id="login-err">Невірний логін або пароль</div>
  </div>
</div>

<!-- LAYOUT -->
<div id="layout" style="display:none">
  <!-- Sidebar -->
  <div id="sidebar">
    <div id="sidebar-logo">
      <h1>★ Адмін-панель</h1>
      <p>Зоряна Памʼять</p>
    </div>
    <div class="nav-item active" onclick="showSection('stats')" data-sec="stats">
      <span class="nav-ico">📊</span> Статистика
    </div>
    <div class="nav-item" onclick="showSection('memorials')" data-sec="memorials">
      <span class="nav-ico">📋</span> Записи
    </div>
    <div class="nav-item" onclick="showSection('pending')" data-sec="pending">
      <span class="nav-ico">⏳</span> На модерації <span id="pending-badge" style="margin-left:auto;background:rgba(212,168,0,.2);color:#d4a800;border-radius:10px;padding:1px 6px;font-size:10px;display:none"></span>
    </div>
    <div class="nav-item" onclick="showSection('users')" data-sec="users">
      <span class="nav-ico">👥</span> Користувачі
    </div>
    <div class="nav-item" onclick="showSection('labels')" data-sec="labels">
      <span class="nav-ico">🗺</span> Підписи карти
    </div>
    <div class="nav-item" onclick="showSection('colors')" data-sec="colors">
      <span class="nav-ico">🎨</span> Кольори / Дизайн
    </div>
    <div id="admin-info">
      <div>Адмін: <strong id="admin-name">—</strong></div>
      <div style="margin-top:4px">Онлайн: <strong id="admin-online">—</strong></div>
      <button id="btn-logout-admin" onclick="adminLogout()">Вийти</button>
    </div>
  </div>

  <!-- Main -->
  <div id="main">

    <!-- Stats -->
    <div id="sec-stats" class="section active">
      <div class="section-title">📊 Статистика</div>
      <div class="stats-grid">
        <div class="stat-card"><div class="num" id="st-total">—</div><div class="lbl">Всього записів</div></div>
        <div class="stat-card"><div class="num" id="st-approved">—</div><div class="lbl">Схвалено</div></div>
        <div class="stat-card"><div class="num" id="st-pending">—</div><div class="lbl">На модерації</div></div>
        <div class="stat-card"><div class="num" id="st-users">—</div><div class="lbl">Користувачів</div></div>
        <div class="stat-card"><div class="num" id="st-likes">—</div><div class="lbl">Зірок</div></div>
        <div class="stat-card"><div class="num" id="st-online">—</div><div class="lbl">Онлайн зараз</div></div>
      </div>
    </div>

    <!-- Memorials -->
    <div id="sec-memorials" class="section">
      <div class="section-title">📋 Всі записи</div>
      <div class="tbl-wrap">
        <table id="mem-table">
          <thead><tr>
            <th>ID</th><th>ПІБ</th><th>Місце пох.</th><th>Місце заг.</th>
            <th>Обст.</th><th>Статус</th><th>Лайки</th><th>Дії</th>
          </tr></thead>
          <tbody id="mem-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Pending -->
    <div id="sec-pending" class="section">
      <div class="section-title">⏳ На модерації</div>
      <div class="tbl-wrap">
        <table>
          <thead><tr>
            <th>ID</th><th>ПІБ</th><th>Місце пох.</th><th>Обст.</th><th>Хто додав</th><th>Дії</th>
          </tr></thead>
          <tbody id="pend-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Users -->
    <div id="sec-users" class="section">
      <div class="section-title">👥 Користувачі</div>
      <div class="tbl-wrap">
        <table>
          <thead><tr>
            <th>ID</th><th>Імʼя</th><th>Email</th><th>Статус</th>
            <th>Онлайн</th><th>Роль</th><th>Дії</th>
          </tr></thead>
          <tbody id="users-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Labels -->
    <div id="sec-labels" class="section">
      <div class="section-title">🗺 Підписи карти</div>
      <p style="color:var(--muted);margin-bottom:16px;font-size:12px">Змініть координати підписів областей на карті. X та Y — відносні координати в системі viewBox карти (0–14000 × 0–9500).</p>
      <div class="tbl-wrap">
        <table>
          <thead><tr><th>Назва</th><th>X</th><th>Y</th><th>Тип</th><th>Дії</th></tr></thead>
          <tbody id="labels-tbody"></tbody>
        </table>
      </div>
    </div>

    <!-- Colors -->
    <div id="sec-colors" class="section">
      <div class="section-title">🎨 Кольори та дизайн</div>

      <!-- Preview -->
      <div id="preview-bar">
        <span class="pbr-label">Попередній перегляд:</span>
        <span id="preview-logo">★ <em style="font-style:normal">Зоряна</em> Памʼять</span>
        <canvas id="preview-map" width="120" height="60"></canvas>
        <span class="pbr-label" id="preview-text-ex">Текст прикладу</span>
      </div>

      <div style="display:flex;gap:10px;margin-bottom:16px">
        <button class="btn btn-primary" onclick="saveAllColors()">💾 Зберегти всі зміни</button>
        <button class="btn" onclick="resetColors()">↺ Скинути до типових</button>
      </div>

      <div class="colors-grid" id="colors-grid"></div>
    </div>

  </div>
</div>

<!-- Edit Modal -->
<div id="edit-modal">
  <div class="edit-box">
    <button id="modal-close-btn" onclick="closeEdit()">✕</button>
    <h3 id="edit-title">Редагування</h3>
    <div class="ef-grid">
      <div class="ef"><label>Прізвище</label><input id="e-last"></div>
      <div class="ef"><label>Імʼя</label><input id="e-first"></div>
      <div class="ef"><label>По батькові</label><input id="e-mid"></div>
      <div class="ef"><label>Колір точки</label><input id="e-color" type="color"></div>
      <div class="ef"><label>Дата нар.</label><input id="e-birth" type="date"></div>
      <div class="ef"><label>Дата заг.</label><input id="e-death" type="date"></div>
      <div class="ef ef-full"><label>Місце загибелі</label><input id="e-loc"></div>
      <div class="ef ef-full"><label>Місце поховання</label><input id="e-bury"></div>
      <div class="ef"><label>Обставини</label>
        <select id="e-circ">
          <option>Міна</option><option>Ракетний удар</option><option>Шахед</option>
          <option>Артилерія</option><option>Прямий контакт</option><option>Снайпер</option>
          <option>Авіабомба</option><option>Полон</option><option>Інше</option>
        </select>
      </div>
      <div class="ef"><label>Статус</label>
        <select id="e-approved">
          <option value="0">На модерації</option>
          <option value="1">Схвалено</option>
        </select>
      </div>
      <div class="ef"><label>X (0–1)</label><input id="e-px" type="number" step="0.001" min="0" max="1"></div>
      <div class="ef"><label>Y (0–1)</label><input id="e-py" type="number" step="0.001" min="0" max="1"></div>
      <div class="ef"><label>Група (дублікати)</label><input id="e-grp"></div>
      <div class="ef"><label>Фото URL</label><input id="e-photo"></div>
      <div class="ef ef-full"><label>Опис</label><textarea id="e-desc"></textarea></div>
    </div>
    <div class="edit-actions">
      <button class="btn" onclick="closeEdit()">Скасувати</button>
      <button class="btn btn-primary" onclick="saveEdit()">💾 Зберегти</button>
    </div>
  </div>
</div>

<div id="admin-notif"></div>

<script>
const API = 'http://127.0.0.1:8000';
let admEmail = '', admPass = '', editId = null;
let colorsData = {};
let pendingColors = {};

// ── LOGIN ─────────────────────────────────────────────
async function adminLogin() {
  const email = document.getElementById('adm-email').value.trim();
  const pass  = document.getElementById('adm-pass').value;
  try {
    const r = await fetch(`${API}/api/auth/login`, {
      method: 'POST', headers: {'Content-Type':'application/json'},
      body: JSON.stringify({email, password: pass})
    });
    const d = await r.json();
    if (!d.ok || !d.user.is_admin) throw new Error();
    admEmail = email; admPass = pass;
    document.getElementById('login-screen').style.display = 'none';
    document.getElementById('layout').style.display = 'flex';
    document.getElementById('admin-name').textContent = d.user.name;
    loadAll();
  } catch {
    document.getElementById('login-err').style.display = 'block';
  }
}

function adminLogout() {
  admEmail=''; admPass='';
  document.getElementById('login-screen').style.display='flex';
  document.getElementById('layout').style.display='none';
}

document.getElementById('adm-pass').addEventListener('keydown', e => {
  if (e.key === 'Enter') adminLogin();
});

// ── NAVIGATION ────────────────────────────────────────
function showSection(id) {
  document.querySelectorAll('.section').forEach(s=>s.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  document.getElementById('sec-'+id).classList.add('active');
  document.querySelector(`[data-sec="${id}"]`).classList.add('active');
  if (id==='memorials') loadMemorials();
  if (id==='pending')   loadPending();
  if (id==='users')     loadUsers();
  if (id==='labels')    loadLabels();
  if (id==='colors')    loadColors();
}

// ── LOAD ALL ──────────────────────────────────────────
async function loadAll() {
  loadStats();
  setInterval(loadStats, 10000);
}

async function loadStats() {
  try {
    const r = await fetch(`${API}/api/admin/stats?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`);
    const d = await r.json();
    document.getElementById('st-total').textContent    = d.total;
    document.getElementById('st-approved').textContent = d.approved;
    document.getElementById('st-pending').textContent  = d.pending;
    document.getElementById('st-users').textContent    = d.users;
    document.getElementById('st-likes').textContent    = d.likes;
    document.getElementById('st-online').textContent   = d.online;
    document.getElementById('admin-online').textContent= d.online;
    const pb = document.getElementById('pending-badge');
    if (d.pending > 0) { pb.textContent = d.pending; pb.style.display='inline'; }
    else { pb.style.display='none'; }
  } catch {}
}

// ── MEMORIALS ─────────────────────────────────────────
async function loadMemorials() {
  const r = await fetch(`${API}/api/people`);
  const people = await r.json();
  const tbody = document.getElementById('mem-tbody');
  tbody.innerHTML = people.map(p => `
    <tr>
      <td style="color:var(--muted)">${p.id}</td>
      <td><strong>${p.last} ${p.first}</strong><br><span style="color:var(--muted);font-size:10px">${p.mid||''}</span></td>
      <td style="font-size:11px">${p.bury||'—'}</td>
      <td style="font-size:11px">${p.loc||'—'}</td>
      <td><span class="badge badge-blue">${p.circ||'—'}</span></td>
      <td><span class="badge ${p.approved?'badge-green':'badge-yellow'}">${p.approved?'Схвалено':'Модерація'}</span></td>
      <td>⭐ ${p.likes||0}</td>
      <td style="display:flex;gap:5px;flex-wrap:wrap">
        <button class="btn btn-blue" onclick="openEdit(${p.id})">✏️</button>
        <button class="btn btn-red" onclick="deleteMem(${p.id})">🗑</button>
      </td>
    </tr>`).join('');
}

// ── PENDING ───────────────────────────────────────────
async function loadPending() {
  const r = await fetch(`${API}/api/admin/pending?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`);
  const people = await r.json();
  const tbody = document.getElementById('pend-tbody');
  if (!people.length) {
    tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:20px">Немає записів на модерації</td></tr>';
    return;
  }
  tbody.innerHTML = people.map(p=>`
    <tr>
      <td style="color:var(--muted)">${p.id}</td>
      <td><strong>${p.last} ${p.first} ${p.mid||''}</strong></td>
      <td style="font-size:11px">${p.bury||'—'}</td>
      <td><span class="badge badge-blue">${p.circ||'—'}</span></td>
      <td style="font-size:11px">${p.added_by||'—'}</td>
      <td style="display:flex;gap:5px">
        <button class="btn btn-green" onclick="approveMem(${p.id})">✅ Схвалити</button>
        <button class="btn btn-blue"  onclick="openEdit(${p.id})">✏️</button>
        <button class="btn btn-red"   onclick="deleteMem(${p.id})">🗑</button>
      </td>
    </tr>`).join('');
}

async function approveMem(id) {
  await fetch(`${API}/api/admin/approve/${id}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,{method:'POST'});
  showNotif('✅ Запис схвалено');
  loadPending(); loadStats();
}

async function deleteMem(id) {
  if (!confirm('Видалити запис?')) return;
  await fetch(`${API}/api/admin/memorial/${id}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,{method:'DELETE'});
  showNotif('🗑 Видалено');
  loadMemorials(); loadPending(); loadStats();
}

// ── EDIT MODAL ────────────────────────────────────────
async function openEdit(id) {
  const r = await fetch(`${API}/api/people`);
  const all = await r.json();
  // Also check pending
  const rp = await fetch(`${API}/api/admin/pending?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`);
  const pend = await rp.json();
  const p = [...all,...pend].find(x=>x.id===id);
  if (!p) return;
  editId = id;
  document.getElementById('edit-title').textContent = `Редагування: ${p.last} ${p.first}`;
  document.getElementById('e-last').value    = p.last||'';
  document.getElementById('e-first').value   = p.first||'';
  document.getElementById('e-mid').value     = p.mid||'';
  document.getElementById('e-color').value   = p.color||'#4fc3f7';
  document.getElementById('e-birth').value   = p.birth||'';
  document.getElementById('e-death').value   = p.death||'';
  document.getElementById('e-loc').value     = p.loc||'';
  document.getElementById('e-bury').value    = p.bury||'';
  document.getElementById('e-circ').value    = p.circ||'';
  document.getElementById('e-approved').value= p.approved||0;
  document.getElementById('e-px').value      = p.pos_x||0.5;
  document.getElementById('e-py').value      = p.pos_y||0.5;
  document.getElementById('e-grp').value     = p.grp||'';
  document.getElementById('e-photo').value   = p.photo||'';
  document.getElementById('e-desc').value    = p.descr||'';
  document.getElementById('edit-modal').classList.add('open');
}

function closeEdit() { document.getElementById('edit-modal').classList.remove('open'); editId=null; }

async function saveEdit() {
  if (!editId) return;
  const body = {
    last:     document.getElementById('e-last').value,
    first:    document.getElementById('e-first').value,
    mid:      document.getElementById('e-mid').value,
    color:    document.getElementById('e-color').value,
    birth:    document.getElementById('e-birth').value||null,
    death:    document.getElementById('e-death').value||null,
    loc:      document.getElementById('e-loc').value,
    bury:     document.getElementById('e-bury').value,
    circ:     document.getElementById('e-circ').value,
    approved: parseInt(document.getElementById('e-approved').value),
    pos_x:    parseFloat(document.getElementById('e-px').value),
    pos_y:    parseFloat(document.getElementById('e-py').value),
    grp:      document.getElementById('e-grp').value,
    photo:    document.getElementById('e-photo').value,
    descr:    document.getElementById('e-desc').value,
  };
  await fetch(`${API}/api/admin/memorial/${editId}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,
    {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
  showNotif('💾 Збережено');
  closeEdit(); loadMemorials(); loadPending();
}

// ── USERS ─────────────────────────────────────────────
async function loadUsers() {
  const r = await fetch(`${API}/api/admin/users?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`);
  const users = await r.json();
  document.getElementById('users-tbody').innerHTML = users.map(u=>`
    <tr>
      <td style="color:var(--muted)">${u.id}</td>
      <td><strong>${u.name}</strong></td>
      <td style="font-size:11px;color:var(--text2)">${u.email}</td>
      <td><span class="badge ${u.is_banned?'badge-red':'badge-green'}">${u.is_banned?'Заблоковано':'Активний'}</span></td>
      <td>${u.online?'<span class="online-dot"></span>Онлайн':'<span style="color:var(--muted)">Офлайн</span>'}</td>
      <td><span class="badge ${u.is_admin?'badge-yellow':'badge-blue'}">${u.is_admin?'Адмін':'Юзер'}</span></td>
      <td style="display:flex;gap:5px">
        ${u.is_banned
          ? `<button class="btn btn-green" onclick="unbanUser(${u.id})">✅ Розблок.</button>`
          : `<button class="btn btn-red"   onclick="banUser(${u.id})">🚫 Бан</button>`
        }
      </td>
    </tr>`).join('');
}

async function banUser(id) {
  if (!confirm('Заблокувати користувача?')) return;
  await fetch(`${API}/api/admin/ban/${id}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,{method:'POST'});
  showNotif('🚫 Заблоковано'); loadUsers();
}
async function unbanUser(id) {
  await fetch(`${API}/api/admin/unban/${id}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,{method:'POST'});
  showNotif('✅ Розблоковано'); loadUsers();
}

// ── LABELS ────────────────────────────────────────────
async function loadLabels() {
  const r = await fetch(`${API}/api/labels`);
  const labels = await r.json();
  document.getElementById('labels-tbody').innerHTML = labels.map(l=>`
    <tr>
      <td><strong>${l.name}</strong></td>
      <td><input type="number" id="lx-${l.id}" value="${l.x}" style="width:80px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 7px;font-size:11px"></td>
      <td><input type="number" id="ly-${l.id}" value="${l.y}" style="width:80px;background:rgba(255,255,255,.04);border:1px solid var(--border);border-radius:6px;color:var(--text);padding:4px 7px;font-size:11px"></td>
      <td><span class="badge badge-blue">${l.type}</span></td>
      <td><button class="btn btn-primary" onclick="saveLabel(${l.id})">💾</button></td>
    </tr>`).join('');
}

async function saveLabel(id) {
  const x = parseFloat(document.getElementById(`lx-${id}`).value);
  const y = parseFloat(document.getElementById(`ly-${id}`).value);
  await fetch(`${API}/api/admin/label/${id}?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,
    {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,x,y})});
  showNotif('💾 Координати збережено');
}

// ── COLORS ────────────────────────────────────────────
async function loadColors() {
  const r = await fetch(`${API}/api/colors`);
  colorsData = await r.json();
  pendingColors = {};
  renderColors();
  updatePreview();
}

function renderColors() {
  const grid = document.getElementById('colors-grid');
  grid.innerHTML = Object.entries(colorsData).map(([key,info])=>{
    const isColor = info.value.startsWith('#') || info.value.startsWith('rgb');
    return `
    <div class="color-row">
      <div class="color-preview" id="cp-${key}" style="background:${info.value}" onclick="document.getElementById('ci-${key}').click()"></div>
      <div class="color-info">
        <div class="color-key">${key}</div>
        <div class="color-lbl">${info.label}</div>
        <div class="color-val" id="cv-${key}">${info.value}</div>
      </div>
      <input ${isColor?'type="color"':'type="text"'} id="ci-${key}" class="color-input"
        value="${isColor&&info.value.startsWith('#')?info.value:info.value}"
        oninput="onColorChange('${key}',this.value)"
        style="${isColor?'padding:2px;width:50px;height:34px;border-radius:6px;cursor:pointer':''}">
    </div>`;
  }).join('');
}

function onColorChange(key, val) {
  pendingColors[key] = val;
  const cp = document.getElementById(`cp-${key}`);
  const cv = document.getElementById(`cv-${key}`);
  if (cp) cp.style.background = val;
  if (cv) cv.textContent = val;
  updatePreview();
}

function updatePreview() {
  const get = key => pendingColors[key] || colorsData[key]?.value || '';
  // Logo
  const logo = document.getElementById('preview-logo');
  if (logo) {
    logo.style.color = get('logo_text');
    logo.style.textShadow = `0 0 12px ${get('logo_star')}60`;
    const em = logo.querySelector('em');
    if (em) em.style.color = get('logo_accent');
  }
  // Preview text
  const pt = document.getElementById('preview-text-ex');
  if (pt) { pt.style.color = get('text_primary'); }
  // Mini map canvas
  const cv = document.getElementById('preview-map');
  if (cv) {
    const ctx = cv.getContext('2d');
    ctx.fillStyle = get('map_bg') || '#03070e';
    ctx.fillRect(0,0,120,60);
    ctx.strokeStyle = get('neon_blue') || '#00ccff';
    ctx.lineWidth = 2;
    ctx.shadowColor = get('neon_blue') || '#00ccff';
    ctx.shadowBlur = 6;
    ctx.beginPath();
    ctx.roundRect(15,10,90,40,6);
    ctx.stroke();
    ctx.shadowBlur = 0;
    ctx.strokeStyle = get('neon_yellow') || '#d4a800';
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(60,10); ctx.lineTo(60,50); ctx.stroke();
    ctx.beginPath(); ctx.moveTo(15,30); ctx.lineTo(105,30); ctx.stroke();
  }
}

async function saveAllColors() {
  if (!Object.keys(pendingColors).length) { showNotif('Немає змін для збереження'); return; }
  const batch = Object.entries(pendingColors).map(([key,value])=>({key,value}));
  await fetch(`${API}/api/admin/colors/batch?email=${encodeURIComponent(admEmail)}&password=${encodeURIComponent(admPass)}`,
    {method:'PUT',headers:{'Content-Type':'application/json'},body:JSON.stringify(batch)});
  showNotif('💾 Кольори збережено! Оновіть сторінку карти.');
  pendingColors = {};
  loadColors();
}

async function resetColors() {
  if (!confirm('Скинути всі кольори до типових?')) return;
  showNotif('Скидання... оновіть сторінку');
}

// ── NOTIF ─────────────────────────────────────────────
let nt=null;
function showNotif(msg,err=false) {
  const el=document.getElementById('admin-notif');
  el.textContent=msg; el.classList.toggle('err',err); el.classList.add('show');
  clearTimeout(nt); nt=setTimeout(()=>el.classList.remove('show'),3000);
}

// WS для онлайн
function connectWS() {
  try {
    const ws = new WebSocket('ws://127.0.0.1:8000/ws/online');
    ws.onmessage = e => { try{ const d=JSON.parse(e.data); if(d.online!==undefined) document.getElementById('admin-online').textContent=d.online; }catch{} };
    ws.onclose = () => setTimeout(connectWS,3000);
    setInterval(()=>{ if(ws.readyState===1) ws.send('ping'); },25000);
  } catch {}
}
connectWS();
</script>
</body>
</html>
