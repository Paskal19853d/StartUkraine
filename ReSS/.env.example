# ============================================================
#  Зоряна Пам'ять — Environment Configuration
#  Скопіюйте цей файл як .env і заповніть значення
# ============================================================

# JWT — ОБОВ'ЯЗКОВО змінити перед деплоєм (мінімум 32 символи)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_OF_AT_LEAST_32_CHARS

# Термін дії токена в годинах (за замовчуванням 8)
TOKEN_EXPIRE_HOURS=8

# Шлях до бази даних (відносно папки ReSS/)
DB_PATH=../memorial.db

# Дозволені origins для CORS (через кому, без пробілів)
ALLOWED_ORIGINS=http://localhost:8001,http://127.0.0.1:8001

# Адміністратор за замовчуванням (створюється при першому запуску)
# ОБОВ'ЯЗКОВО змінити пароль!
ADMIN_EMAIL=admin@memorial.ua
ADMIN_PASS=ChangeMe_Admin2024!
