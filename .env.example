# ── Зоряна Пам'ять — конфігурація (приклад) ──────────────
# Скопіюйте в .env та заповніть своїми значеннями:
# cp .env.example .env

# ── MySQL / MariaDB підключення ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=zoryana_pamyat

# ── Connection Pool (опціонально) ────────────────────────
# DB_POOL_SIZE=50
# DB_POOL_MINCACHED=5
# DB_POOL_MAXCACHED=20

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://127.0.0.1:8000

# ─-- Дія OAuth ───────────────────────────────────────────
DIIA_CLIENT_ID=
DIIA_CLIENT_SECRET=

# ── alerts.inua API ───────────────────────────────────
ALERTS_API_KEY=

# ── Redis (опціонально — для кешування) ──────────────────
REDIS_URL=redis://127.0.0.1:6379/0
