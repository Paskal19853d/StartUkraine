# ── Зоряна Пам'ять — конфігурація (приклад) ──────────────
# Скопіюйте в .env та заповніть своїми значеннями:
# cp .env.example .env

# ── MySQL / MariaDB підключення ──────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=root
DB_NAME=zoryana_pamyat

# ── Connection Pool (опціонально) ────────────────────────
# DB_POOL_SIZE=50
# DB_POOL_MINCACHED=5
# DB_POOL_MAXCACHED=20

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─-- Дія OAuth ───────────────────────────────────────────
DIIA_CLIENT_ID=
DIIA_CLIENT_SECRET=

# ── alerts.inua API ───────────────────────────────────
ALERTS_API_KEY=

# ── Redis (опціонально — для кешування) ──────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── SMTP (відправка email-кодів підтвердження реєстрації) ─
# Gmail: включіть "Двохетапна перевірка" і створіть "Пароль додатку"
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-account@gmail.com
SMTP_PASS=your-app-password-16chars
# Ім'я відправника (якщо відрізняється від SMTP_USER):
SMTP_FROM=Зоряна Пам'ять <your-account@gmail.com>
# Якщо SMTP_HOST/SMTP_USER порожні — dev-режим: код повертається у відповіді API

# ── Домен і CORS ─────────────────────────────────────────
# Публічна URL сайту (без слешу в кінці):
SITE_BASE_URL=https://your-domain.com
# База для OAuth redirect URI (зазвичай = SITE_BASE_URL):
OAUTH_REDIRECT_BASE=https://your-domain.com
# Дозволені origins для CORS (через кому; додайте всі домени):
ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# ── Gunicorn (production) ─────────────────────────────────
# Адреса прив'язки. 127.0.0.1 — тільки через Nginx; 0.0.0.0 — напряму
GUNICORN_BIND=127.0.0.1:8000

# ── Безпека ───────────────────────────────────────────────
# ENVIRONMENT=production  # Розкоментувати для production (вмикає secure cookies, HSTS)
# METRICS_TOKEN=          # Токен доступу до /metrics (Bearer). Якщо порожньо — відкритий доступ (dev)
